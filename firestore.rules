rules_version = '2';
service cloud.firestore {
    match /databases/{database}/documents {
        match /userStates/{userId} {
            allow read, write: if request.auth != null && request.auth.uid == userId;
        }

        match /profiles/{userId} {
            allow read: if true;
            allow create, update: if request.auth != null && request.auth.uid == userId;
        }

        match /handles/{handle} {
            allow read: if request.auth != null;
            allow create: if request.auth != null
                && request.resource.data.uid == request.auth.uid
                && !exists(/databases/$(database)/documents/handles/$(handle));
            allow update, delete: if false;
        }

        match /friendships/{friendshipId} {
            allow read: if request.auth != null && request.auth.uid in resource.data.users;
            allow create, update: if request.auth != null
                && request.auth.uid in request.resource.data.users
                && request.resource.data.users.size() == 2
                && request.resource.data.status == 'accepted';
        }

        match /socialRequests/{requestId} {
            allow read, delete: if request.auth != null
                && (
                    ('users' in resource.data && request.auth.uid in resource.data.users)
                    || request.auth.uid == resource.data.fromUserId
                    || request.auth.uid == resource.data.toUserId
                );
            allow create: if request.auth != null
                && request.auth.uid == request.resource.data.fromUserId
                && request.resource.data.toUserId is string
                && (
                    !('users' in request.resource.data)
                    || (
                        request.resource.data.users.size() == 2
                        && request.auth.uid in request.resource.data.users
                        && request.resource.data.toUserId in request.resource.data.users
                    )
                )
                && request.resource.data.status == 'pending';
            allow update: if false;
        }

        match /bookingPresets/{documentId} {
            allow read: if request.auth != null;
            allow create, update: if request.auth != null;
        }

        match /bookingSlots/{slotId} {
            allow read: if request.auth != null;
            allow create: if request.auth != null
                && request.resource.data.source == 'preset'
                && (!('participantIds' in request.resource.data) || request.resource.data.participantIds.size() == 0)
                && (!('waitlistIds' in request.resource.data) || request.resource.data.waitlistIds.size() == 0);
            allow update: if false;
        }

        match /bookingLeaderboards/{documentId} {
            allow read: if request.auth != null;
            allow create, update: if false;
        }

        match /bookingDistrictMetrics/{documentId} {
            allow read: if request.auth != null;
            allow create, update: if false;
        }

        match /venueWeatherCache/{documentId} {
            allow read: if request.auth != null;
            allow write: if false;
        }

        match /pickupGames/{gameId} {
            // Publicly discoverable so shared links resolve before sign-in.
            allow read: if true;

            // Only the host can create, and they must seed themselves as the
            // sole member.
            allow create: if request.auth != null
                && request.resource.data.creatorId == request.auth.uid
                && request.resource.data.joinedPlayerIds is list
                && request.resource.data.joinedPlayerIds.size() == 1
                && request.resource.data.joinedPlayerIds[0] == request.auth.uid;

            // The creator may edit or manage members freely; any other player
            // may ONLY add or remove their own uid (join / leave), and joining
            // may not exceed capacity.
            allow update: if request.auth != null && (
                request.auth.uid == resource.data.creatorId
                || (
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['joinedPlayerIds'])
                    && (
                        (
                            !(request.auth.uid in resource.data.joinedPlayerIds)
                            && request.resource.data.joinedPlayerIds.hasOnly(resource.data.joinedPlayerIds.concat([request.auth.uid]))
                            && request.resource.data.joinedPlayerIds.hasAll(resource.data.joinedPlayerIds)
                            && request.resource.data.joinedPlayerIds.size() == resource.data.joinedPlayerIds.size() + 1
                            && request.resource.data.joinedPlayerIds.size() <= resource.data.spotsTotal
                        )
                        || (
                            (request.auth.uid in resource.data.joinedPlayerIds)
                            && !(request.auth.uid in request.resource.data.joinedPlayerIds)
                            && resource.data.joinedPlayerIds.hasOnly(request.resource.data.joinedPlayerIds.concat([request.auth.uid]))
                            && resource.data.joinedPlayerIds.hasAll(request.resource.data.joinedPlayerIds)
                            && request.resource.data.joinedPlayerIds.size() == resource.data.joinedPlayerIds.size() - 1
                        )
                    )
                )
            );

            allow delete: if request.auth != null
                && request.auth.uid == resource.data.creatorId;
        }

        match /{document=**} {
            allow read, write: if false;
        }
    }
}